{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "dicom-curate": ["src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "e2e/**/*",
    "testutils/**/*",
    "vitest.setup.ts",
    "vitest.config.ts",
    "vitest-env.d.ts",
    "conformance/**/*",
    "scripts/update-conformance-baselines.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
