{
  "name": "dicom-curate",
  "version": "0.40.6",
  "repository": {
    "type": "git",
    "url": "https://github.com/clintools/dicom-curate"
  },
  "packageManager": "pnpm@10.15.0",
  "description": "Organize and de-identify DICOM header data ",
  "type": "module",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./umd": {
      "require": "./dist/umd/dicom-curate.umd.js"
    },
    "./umd.min": {
      "require": "./dist/umd/dicom-curate.umd.min.js"
    }
  },
  "files": [
    "dist"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,mts,json,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "scripts": {
    "pre-commit:check": "tsc --noEmit && pnpm lint",
    "clean": "rm -rf dist",
    "build": "pnpm generate:sampleSpec && pnpm build:esm && pnpm build:types && rollup -c",
    "build:esm": "node esbuild.config.js",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types -p tsconfig.build.json && tsx scripts/fixDtsExtensions.ts",
    "watch": "node esbuild.config.js --watch",
    "pretest": "pnpm build:esm",
    "test": "vitest run --pool=forks --project unit",
    "test:e2e": "pnpm build:esm && vitest run --pool=forks --project e2e",
    "test:conformance": "vitest run --pool=forks --project conformance",
    "update:conformance-baselines": "esbuild scripts/update-conformance-baselines.ts --bundle --platform=node --format=esm --external:dicom-synth --outfile=conformance/.update-conformance-baselines.mjs && node conformance/.update-conformance-baselines.mjs",
    "test:coverage": "vitest run --pool=forks --project unit --coverage",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "prepare": "husky install && pnpm build",
    "generate:sampleSpec": "tsx scripts/generateSampleSpec.ts",
    "generate:unitTestSample": "tsx scripts/generateSampleDicomData.ts",
    "validate": "pnpm build && pnpm test",
    "check": "biome check .",
    "check:errors": "biome check . --diagnostic-level=error",
    "check:fix": "biome check . --write"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/lib-storage": "^3.940.0",
    "@noble/hashes": "^2.0.1",
    "acorn": "^8.14.1",
    "acorn-globals": "^7.0.1",
    "dcmjs": "^0.51.1",
    "iso8601-duration": "^2.1.2",
    "js-crc": "^0.3.0",
    "lodash": "^4.17.21",
    "memize": "^2.1.0",
    "picomatch": "^4.0.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.34.0",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.3",
    "@semantic-release/npm": "^13.1.3",
    "@types/lodash": "^4",
    "@types/picomatch": "^4.0.2",
    "@types/wicg-file-system-access": "^2023.10.6",
    "@types/xml2js": "^0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitest/coverage-v8": "^3.2.4",
    "commander": "^14.0.3",
    "dicom-synth": "^2.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "husky": "^8.0.3",
    "lint-staged": "^16.1.5",
    "node-fetch": "^3.3.2",
    "prettier": "^3.4.2",
    "rollup": "^4.43.0",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-web-worker-loader": "^1.7.0",
    "semantic-release": "^25.0.3",
    "tslib": "^2.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "xml2js": "^0.6.2"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  }
}
